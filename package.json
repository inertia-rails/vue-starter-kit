{
  "name": "vue_starter_kit",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vue-tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "eslint '*.{js,mjs,cjs,ts}' app/javascript/ --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint '*.{js,mjs,cjs,ts}' app/javascript/ --fix",
    "format": "prettier --check 'app/javascript' '*.{js,mjs,cjs,ts}'",
    "format:fix": "prettier --write 'app/javascript' '*.{js,mjs,cjs,ts}'"
  },
  "dependencies": {
    "@inertiajs/vue3": "^3.6.1",
    "@lucide/vue": "^1.26.0",
    "@vueuse/core": "^14.3.0",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.40",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@inertiajs/core": "^3.6.1",
    "@inertiajs/vite": "^3.6.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.10.0",
    "lucide-vue-next": "^1.0.0",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "rails-vite-plugin": "^0.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0",
    "vite": "^8.1.5",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue-tsc": "^3.3.8"
  }
}
